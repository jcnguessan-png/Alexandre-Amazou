# ============================================================
# alexandreamazou.com — variables d'environnement
# Copier ce fichier en `.env.local` et renseigner les valeurs.
# ============================================================

# YouTube Data API v3
# Console : https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
# Chaîne YouTube principale du Pasteur (UCi2WIBsPCQycQK2NYwKA61Q d'après l'audit ;
# à confirmer — l'audit signale une seconde chaîne UCwqHNYIvsrNQBgTvhD1XgEA)
YOUTUBE_CHANNEL_ID=UCi2WIBsPCQycQK2NYwKA61Q
# Playlist principale affichée sur le site (curation officielle)
YOUTUBE_FEATURED_PLAYLIST_ID=PL1j6au4j0Fs5oAbh6rg9SvMCi7AbUgVBI

# Brevo (newsletter)
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=
BREVO_LIST_ID=

# Cloudflare Turnstile (anti-spam, alternative au captcha mathématique)
# https://dash.cloudflare.com/?to=/:account/turnstile
CLOUDFLARE_TURNSTILE_SECRET=
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITEKEY=

# URL canonique du site (utilisée pour OG, Schema.org, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://alexandreamazou.com

# Plausible Analytics (privacy-first)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=alexandreamazou.com

# Email destinataire du formulaire de contact
CONTACT_EMAIL_TO=contact@alexandreamazou.com
CONTACT_EMAIL_FROM=no-reply@alexandreamazou.com

# Assistant / chatbot (API Claude — Anthropic)
# Clé API : https://console.anthropic.com/settings/keys
# Sans clé, le widget reste affiché mais renvoie vers WhatsApp.
ANTHROPIC_API_KEY=
# Modèle utilisé par le bot. Défaut : claude-opus-4-8 (le plus capable).
# Pour un bot public à fort trafic, claude-haiku-4-5 est nettement moins cher.
CHATBOT_MODEL=claude-opus-4-8
